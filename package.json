{
  "name": "breakdex-expo",
  "version": "1.0.0",
  "main": "AppEntry.js",
  "scheme": "breakdex",
  "scripts": {
    "start": "npm run build:runtime && expo start --clear",
    "start:cljs": "shadow-cljs watch app",
    "android": "npm run build:runtime && expo run:android",
    "ios": "npm run build:runtime && expo run:ios",
    "web": "npm run build:runtime && expo start --web --clear",
    "prebuild": "expo prebuild",
    "build:tokens": "node scripts/build-carbon-tokens.mjs",
    "build:runtime": "npm run build:tokens && npm run build:cljs",
    "build:cljs": "shadow-cljs compile app",
    "build:release": "shadow-cljs release app",
    "build:all": "shadow-cljs compile app && shadow-cljs release app",
    "postinstall": "node scripts/fix-react-native-screens-ios.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "^6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "@supabase/supabase-js": "^2.103.3",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "^8.0.11",
    "expo-router": "~6.0.23",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-elements": "^3.4.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^55.0.18",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "shadow-cljs": "^2.22.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
