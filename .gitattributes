# Git Attributes for Breakdex

# Text files should use LF line endings
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.clj text eol=lf
*.cljs text eol=lf
*.edn text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Configuration files
*.json text
*.yaml text
*.yml text

# Script files
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary
*.pdf binary
*.zip binary

# IDE/Runtime files
.idea/ -linguist-generated
.vscode/ -linguist-generated
*.swp -linguist-generated
*.swo -linguist-generated
*~ -linguist-generated

# Dependencies
node_modules/ -linguist-generated

# Build outputs
out/ -linguist-generated
target/ -linguist-generated
dist/ -linguist-generated
web-build/ -linguist-generated
.android/ -linguist-generated
.ios/ -linguist-generated

# Cache files
.cpcache/ -linguist-generated
.shadow-cljs/ -linguist-generated
.maestro/ -linguist-generated
.opencode/ -linguist-generated

# Diff settings for specific file types
*.clj diff=clojure
*.cljs diff=clojure
*.edn diff=clojure
